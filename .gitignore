# =========================
# Kirsch Stress Index (KSI)
# =========================
# Ignore massive engine binaries and neural net weights
engines/stockfish/*
!engines/stockfish/.gitkeep
engines/lc0/*
!engines/lc0/.gitkeep

# Ignore user-provided PGNs (except the sample game)
games/*
!games/sample_game.pgn
!games/.gitkeep

# Ignore generated dashboards, CSVs, and storyboards
output/*
!output/.gitkeep

